{
    "buildCommand": "npx vite build",
    "outputDirectory": "dist/public",
    "installCommand": "pnpm install --no-frozen-lockfile",
    "framework": null,
    "rewrites": [
      {
        "source": "/api/:path*",
        "destination": "/api/index"
      },
      {
        "source": "/:path*",
        "destination": "/index.html"
      }
    ]
  }